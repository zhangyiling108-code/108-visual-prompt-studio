# Required: set at least one provider key
QWEN_API_KEY=your_qwen_api_key_here
MINIMAX_API_KEY=your_minimax_api_key_here

# Optional endpoint overrides
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
MINIMAX_API_HOST=https://api.minimax.io/v1/text/chatcompletion_v2

# Optional model overrides
QWEN_MODEL=qwen3-vl-plus
MINIMAX_MODEL=MiniMax-M2.7

# Optional runtime tuning
VISUAL_PROMPT_TIMEOUT_MS=60000
VISUAL_PROMPT_RETRIES=2
